#!/bin/sh

file="$(
	{
		echo "$XDG_DATA_HOME"
		echo "$XDG_DATA_DIRS" | tr : '\n'
	} \
	| sed -E -e 's|$|/applications|' \
	| tr '\n' '\0' \
	| find -files0-from - -name "$FUZZEL_DESKTOP_FILE_ID" 2>/dev/null \
	| head -n1
)"
[ -z "$file" ] && exit 1
cmd="$(sed -n '/^Exec=/ { s///; s/ *%u//g; p; q; }' "$file")"
[ -z "$cmd" ] && exit 1
wl-proxy -a "$(basename "$FUZZEL_DESKTOP_FILE_ID" .desktop)-floating" -- $cmd
